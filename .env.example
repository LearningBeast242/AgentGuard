# Required for the complete Build Week defense demo and OpenAI hosted shell.
OPENAI_API_KEY=

# Optional development fallback for model proposals and agent generation.
# It cannot execute OpenAI hosted shell controls.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-5.6-luna

# Optional. Required only for explicitly approved live Gmail delivery.
GMAIL_ACCESS_TOKEN=

# Optional public authentication provider.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Local API access is allowed only when this is exactly "development".
ENVIRONMENT=development
